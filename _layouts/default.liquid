<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page.title | default: site.title }}</title>


    <style>
      :root {
        --accent: #7c3aed; 
        --text-main: #111827; /* Darker for better readability */
        --text-muted: #6b7280;
        --bg-color: #ffffff;
        --border-color: #e5e7eb;
        --font-sans: monospace, -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }

      * { box-sizing: border-box; }

      body {
        max-width: 850px;
        margin: 0 auto;
        padding: 0 1.5rem;
        background: var(--bg-color);
        color: var(--text-main);
        font-family: var(--font-sans);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* --- HEADER --- */
      header.site-header {
        padding: 4rem 0 1rem 0;
      }

      .logo-link {
        text-decoration: none;
        color: var(--text-main);
        transition: opacity 0.2s;
      }

      .logo-link:hover { opacity: 0.7; }

      header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.02em;
      }

      .tagline {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin: 0.5rem 0 0 0;
      }

      /* --- NAVIGATION --- */
      nav.main-nav {
        margin: 2rem 0 4rem 0;
        display: flex;
        gap: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
      }

      nav.main-nav a {
        text-decoration: none;
        color: var(--text-main);
        font-weight: 600;
        font-size: 1rem;
        position: relative;
      }

      nav.main-nav a:hover { color: var(--accent); }
      
      /* Active state indicator */
      nav.main-nav a.active { color: var(--accent); }

      /* --- CONTENT STYLING --- */
      main {
        font-size: 1rem; /* Slightly larger base font for readability */
      }

      h2, h3, h4 {
        color: var(--text-main);
        margin-top: 2.5rem;
        font-weight: 800;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Post List Overrides (Matches your index.md) */
      .posts-list { list-style: none; padding: 0; }
      
      .post-item {
        display: flex;
        gap: 3rem;
        margin-bottom: 3.5rem;
      }

      .post-date .day {
        font-size: 3rem;
        font-weight: 800;
        display: block;
        line-height: 0.9;
        color: #e5e7eb; /* Light grey for that "background" date feel */
      }

      .post-date .month-year {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--text-muted);
        display: block;
        margin-top: 0.2rem;
      }

      .post-info h3 { margin: 0; font-size: 1.5rem; line-height: 1.2; }
      .post-info p { margin: 0.5rem 0 0 0; color: var(--text-muted); font-size: 1rem; }

      /* Mobile adjustments */
      @media (max-width: 600px) {
        .post-item { flex-direction: column; gap: 0.5rem; }
        .post-date { text-align: left; }
        header h1 { font-size: 1.8rem; }
      }
    </style>
  </head>
  
  <body>
    <header class="site-header">
      <a href="/" class="logo-link">
        <h1>{{ site.title }}</h1>
      </a>
      <p class="tagline">{{ site.description }}</p>
    </header>

    <nav class="main-nav">
      <a href="{{ '/' | relative_url }}">Blog</a>
      <a href="{{ '/projects/' | relative_url }}">Projects</a>
      <a href="{{ '/tech-stack/' | relative_url }}">Tech Stack</a>
      <a href="{{ '/about/' | relative_url }}">About</a>
    </nav>
    
    <main>
      {{ content }}
    </main>

    <footer style="margin: 6rem 0 3rem 0; color: var(--text-muted); font-size: 0.9rem;">
      <p>&copy; {{ "now" | date: "%Y" }} • {{ site.title }}</p>
    </footer>
  </body>
</html>