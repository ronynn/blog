<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page.title | default: site.title }}</title>
    <link rel="icon" type="image/png" href="/assets/images/favicon-32x32.png">
    <meta name="description" content="A blog about overthinking analytically, foss apps and video games.">

    <script data-goatcounter="https://ronynn.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/normalize.css@8.0.1/normalize.min.css"> 
    <link rel="stylesheet" href="{{ 'milligram.css' | relative_url }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ '/feed.xml' | relative_url }}">
    
    <style>
        /* Ink-style Layout Overrides */
        :root {
            --ink-purple: #7c3aed; /* Keeping this as the accent color reference */
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
        }
        
        body {
            padding: 4rem 2rem;
            max-width: 900px;
            margin: 0 auto;
        }

        #vanta-bg {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
        }

        /* Top Bar: Title on Left, Controls on Right */
        .site-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .site-title-area h1 {
            margin-bottom: 0;
            font-size: 3.5rem;
            font-weight: 800;
        }

        .controls {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        #theme-selector {
            margin-bottom: 0; /* Override Milligram margin */
            padding: 0.5rem;
            width: auto;
        }

        /* Horizontal Navigation */
        .ink-nav {
            display: flex;
            gap: 2rem;
            border-bottom: 1px solid #eee;
            margin-bottom: 3rem;
            padding-bottom: 1rem;
        }

        .ink-nav a {
            text-decoration: none;
            font-weight: 600;
            color: inherit;
        }

        /* Ink Post List Layout */
        .posts-list {
            list-style: none;
            padding: 0;
        }

        .post-entry {
            display: flex;
            gap: 3rem;
            margin-bottom: 4rem;
            align-items: flex-start;
        }

        .post-date-sidebar {
            min-width: 80px;
            text-align: center;
            color: #999;
        }

        .post-content-area h3 {
            margin-bottom: 0.5rem;
            color: var(--ink-purple); /* Using the Ink signature color for titles */
        }

        /* Clean up Milligram's default list markers for our post list */
        .posts-list li:before {
            content: "" !important;
        }

        @media (max-width: 600px) {
            .post-entry { flex-direction: column; gap: 0.5rem; }
            .site-header { flex-direction: column; }
            .controls { margin-top: 1rem; width: 100%; justify-content: space-between; }
        }
    </style>
</head>

<body data-theme="{{ site.default_theme | default: '' }}">
    <div id="vanta-bg"></div>

    <header class="site-header">
        <div class="site-title-area">
            <h1>{{ site.title }}</h1>
            <p>{{ site.description }}</p>
        </div>
        
        <div class="controls">
            <select id="theme-selector">
                <option value="">Default</option>
                <option value="gruvbox">Gruvbox</option>
                <option value="monokai">Monokai</option>
                <option value="dracula">Dracula</option>
                <option value="nord">Nord</option>
                <option value="solarized">Solarized</option>
                <option value="catppuccin">Catppuccin</option>
                <option value="tokyo-night">Tokyo Night</option>
                <option value="everforest">Everforest</option>
                <option value="cupcake">Cupcake</option>
            </select>
            <button id="toggle-vanta" class="button button-outline">3D</button>
        </div>
    </header>

    <nav class="ink-nav">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/tags">Tags</a>
        <a href="/about">About</a>
    </nav>

    <main>
        <ul class="posts-list">
            {% for post in site.posts %}
            <li class="post-entry">
                <div class="post-date-sidebar">
                    <span style="font-size: 2rem; font-weight: bold; display: block; line-height: 1;">{{ post.date | date: "%d" }}</span>
                    <span style="font-size: 0.8rem; text-transform: uppercase;">{{ post.date | date: "%b %Y" }}</span>
                </div>
                <div class="post-content-area">
                    <h3><a href="{{ post.url | relative_url }}">{{ post.title }}</a></h3>
                    <p>{{ post.excerpt | strip_html | truncatewords: 20 }}</p>
                </div>
            </li>
            {% endfor %}
        </ul>
        
        {{ content }}
    </main>

    <script>
        // ... (Keep your existing Vanta and Theme JS exactly as it was) ...
        var vantaEffect;
        var vantaOn = localStorage.getItem('vantaOn') === "true";
        var savedTheme = localStorage.getItem('selectedTheme') || '';
        document.body.setAttribute('data-theme', savedTheme);

        function loadScript(src, callback) {
            var script = document.createElement("script");
            script.src = src; script.async = true; script.onload = callback;
            document.body.appendChild(script);
        }

        function initVanta() {
            if (vantaEffect) vantaEffect.destroy();
            vantaEffect = VANTA.DOTS({
                el: "#vanta-bg",
                color: getComputedStyle(document.body).getPropertyValue('--button').trim() || 0x000000,
                backgroundColor: getComputedStyle(document.body).getPropertyValue('--bg').trim() || 0xffffff,
                scaleMobile: 1.00,
                showLines: false
            });
        }

        function enableVanta() {
            if (!window.THREE) {
                loadScript("https://cdnjs.cloudflare.com/ajax/libs/three.js/r121/three.min.js", function() {
                    loadScript("https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.dots.min.js", function() {
                        initVanta();
                    });
                });
            } else { initVanta(); }
        }

        if (vantaOn) { enableVanta(); }

        document.getElementById('toggle-vanta').addEventListener('click', function() {
            if (vantaOn) {
                if (vantaEffect) vantaEffect.destroy();
                vantaOn = false;
                localStorage.setItem('vantaOn', "false");
            } else {
                enableVanta();
                vantaOn = true;
                localStorage.setItem('vantaOn', "true");
            }
        });

        document.getElementById('theme-selector').addEventListener('change', function() {
            var selectedTheme = this.value;
            document.body.setAttribute('data-theme', selectedTheme);
            localStorage.setItem('selectedTheme', selectedTheme);
            if (vantaOn && window.VANTA) { initVanta(); }
        });
    </script>
</body>
</html>